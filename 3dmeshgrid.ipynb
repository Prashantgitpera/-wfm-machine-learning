      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "x,y = np.arange(-5,5,0.1), np.arange(-5,5,0.1)\n",
        "ax=plt.axes(projection='3d')\n",
        "\n",
        "X, Y=np.meshgrid(x,y)\n",
        "Z=np.sin(X)*np.cos(Y)\n",
        "ax.plot_surface(X,Y,Z)\n",
        "plt.show()"
      ]
