      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "h=np.random.normal(160,30,1000)\n",
        "\n",
        "plt.boxplot(h,vert=True,patch_artist=True)\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "d11c783a"
      },
      "source": [
        "mean_h = np.mean(h)\n",
        "median_h = np.median(h)\n",
        "\n",
        "print(f\"Mean of h: {mean_h:.2f}\")\n",
        "print(f\"Median of h: {median_h:.2f}\")"
      ],
