      "source": [
        "def find_unique(arr):\n",
        "    res = 0\n",
        "    for num in arr:\n",
        "        res = res ^ num\n",
        "    return res\n",
        "\n",
        "A = [2, 3, 4, 3, 2]\n",
        "print(f\"The array A is: {A}\")\n",
        "print(f\"The unique element in A is: {find_unique(A)}\")"
      ],
      "execution_count": null,
      "outputs": []
    }
